# Токен Telegram бота, полученный у @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram ID администраторов / модераторов через запятую (например: 123456789,987654321)
ADMIN_IDS=your_telegram_id_here

# URL хостинга Telegram Mini App (например: https://your-username.github.io/app/ или https://miniapp.vercel.app)
WEBAPP_URL=https://your-miniapp-domain.com

# Порт для веб-сервера API бота
PORT=8080

